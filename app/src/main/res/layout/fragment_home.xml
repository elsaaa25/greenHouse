<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".fragment.HomeFragment">

    <!-- SCROLLVIEW -->
    <ScrollView
        android:id="@+id/scrollViewHome"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingTop="110dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- CARD UTAMA TANAMAN -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="-30dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPakcoy"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    app:cardBackgroundColor="@color/green_cardbg"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:orientation="vertical"
                        android:paddingStart="20dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tanaman yang dibudidaya"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pakcoy"
                            android:textColor="@color/white"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins" />

                        <TextView
                            android:id="@+id/tvStatus"
                            android:layout_width="130dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_status_watering"
                            android:gravity="center"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:text="Monitoring Aktif"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <ImageView
                    android:id="@+id/ivPlant"
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    android:translationY="-30dp"
                    android:translationX="40dp"
                    android:rotation="15"
                    android:src="@drawable/pakcoy"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- JUDUL SENSOR -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="18dp"
                android:text="Sensor Real-Time"
                android:textColor="@color/gray_dark"
                android:textStyle="bold"
                android:fontFamily="@font/poppins" />

            <!-- BARIS 1: KELEMBAPAN & STATUS ALAT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <!-- Card Kelembapan -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/green_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentTop="true"
                            android:layout_marginTop="5dp"
                            android:src="@drawable/ic_humidity" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Kelembapan"
                            android:textColor="@color/gray_dark"
                            android:fontFamily="@font/poppins" />

                        <TextView
                            android:id="@+id/tvKelembapan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="25dp"
                            android:text="--"
                            android:textColor="@color/gray_dark"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="55dp"
                            android:text="Soil sensor"
                            android:textSize="10sp"
                            android:textColor="@color/gray_dark"
                            android:fontFamily="@font/poppins" />

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card Status Alat -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/green_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginTop="5dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentTop="true"
                            android:src="@drawable/ic_pump" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status Alat"
                            android:textColor="@color/gray_dark"
                            android:fontFamily="@font/poppins" />

                        <TextView
                            android:id="@+id/tvStatusAlat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="25dp"
                            android:text="OFF"
                            android:textColor="@color/gray_dark"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins" />

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- BARIS 2: LAMPU & POMPA AIR MANUAL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <!-- Card Lampu -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/green_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/labelLampu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lampu"
                            android:textColor="@color/gray_dark"
                            android:fontFamily="@font/poppins" />

                        <TextView
                            android:id="@+id/tvLampuStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/labelLampu"
                            android:text="OFF"
                            android:textColor="@color/gray_dark"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tvLampuStatus"
                            android:text="Manual"
                            android:textColor="@color/gray_dark"
                            android:textSize="10sp"
                            android:fontFamily="@font/poppins" />

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentTop="true"
                            android:src="@drawable/ic_light" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchLampu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:layout_marginBottom="-10dp"
                            android:checked="false" />

                    </RelativeLayout>

                </androidx.cardview.widget.CardView>

                <!-- Card Pompa Air -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/green_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/labelPompa"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pompa Air"
                            android:textColor="@color/gray_dark"
                            android:fontFamily="@font/poppins" />

                        <TextView
                            android:id="@+id/tvPompaStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/labelPompa"
                            android:text="OFF"
                            android:textColor="@color/gray_dark"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tvPompaStatus"
                            android:text="Manual"
                            android:textColor="@color/gray_dark"
                            android:textSize="10sp"
                            android:fontFamily="@font/poppins" />

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentTop="true"
                            android:src="@drawable/ic_pump" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchPompa"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:layout_marginBottom="-10dp"
                            android:checked="false" />

                    </RelativeLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- BARIS 3: MODE OTOMATIS LAMPU & POMPA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <!-- Card Mode Lampu -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/green_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/labelModeLampu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mode Lampu"
                            android:textColor="@color/gray_dark"
                            android:fontFamily="@font/poppins" />

                        <TextView
                            android:id="@+id/tvLampuMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/labelModeLampu"
                            android:text="MANUAL"
                            android:textColor="@color/gray_dark"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tvLampuMode"
                            android:text="Auto LDR"
                            android:textColor="@color/gray_dark"
                            android:textSize="10sp"
                            android:fontFamily="@font/poppins" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchLampuAuto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:layout_marginBottom="-10dp"
                            android:checked="false" />

                    </RelativeLayout>

                </androidx.cardview.widget.CardView>

                <!-- Card Mode Pompa -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/green_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/labelModePompa"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mode Pompa"
                            android:textColor="@color/gray_dark"
                            android:fontFamily="@font/poppins" />

                        <TextView
                            android:id="@+id/tvPompaMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/labelModePompa"
                            android:text="MANUAL"
                            android:textColor="@color/gray_dark"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tvPompaMode"
                            android:text="Auto soil"
                            android:textColor="@color/gray_dark"
                            android:textSize="10sp"
                            android:fontFamily="@font/poppins" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchPompaAuto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:layout_marginBottom="-10dp"
                            android:checked="false" />

                    </RelativeLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- JUDUL GRAFIK -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                android:text="Grafik Kelembapan"
                android:textColor="@color/gray_dark"
                android:textStyle="bold"
                android:fontFamily="@font/poppins" />

            <!-- CARD GRAFIK -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Data kelembapan dari sensor"
                        android:textColor="@color/gray_dark"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/lineChart"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="16dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <!-- HEADER SECTION -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="@color/green_primary"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="10dp"
        android:paddingTop="20dp"
        android:paddingBottom="10dp"
        android:elevation="12dp"
        android:translationZ="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selamat datang di Planti"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:layout_marginBottom="2dp"
            android:fontFamily="@font/poppins" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_farmer" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
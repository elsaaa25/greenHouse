<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Warna hijau sesuai dengan gambar -->
    <solid android:color="#7EA061" />

    <!-- Membuat sudut melengkung sempurna (kapsul) -->
    <corners android:radius="100dp" />

    <!-- Jika ingin menambahkan padding agar teks tidak terlalu menempel ke pinggir -->
    <padding
        android:left="12dp"
        android:top="4dp"
        android:right="12dp"
        android:bottom="4dp" />
</shape>